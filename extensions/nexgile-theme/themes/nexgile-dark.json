{
  "name": "Nexgile Dark Enterprise",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "newOperator": "#60a5fa",
    "stringLiteral": "#2dd4bf",
    "customLiteral": "#fbbf24",
    "numberLiteral": "#fbbf24",
    "enumMember": "#22d3ee",
    "macro": "#fb923c",
    "type": "#22d3ee",
    "class": "#22d3ee",
    "interface": "#22d3ee",
    "struct": "#22d3ee",
    "function": "#c084fc",
    "method": "#c084fc",
    "property": "#e2e8f0",
    "variable.readonly": "#fb923c",
    "parameter": "#e2e8f0"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": ["keyword.control", "keyword.operator.new", "keyword.operator.expression", "keyword.operator.logical"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": {
        "foreground": "#2dd4bf"
      }
    },
    {
      "scope": ["string.template", "punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#2dd4bf"
      }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#22d3ee",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember", "constant.other", "constant.language"],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "punctuation"],
      "settings": {
        "foreground": "#94a3b8"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color"],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": ["meta.selector.css"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "scope": ["entity.name.function.decorator", "meta.decorator"],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#60a5fa",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#2dd4bf"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#f87171"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": {
        "foreground": "#e2e8f0"
      }
    }
  ],
