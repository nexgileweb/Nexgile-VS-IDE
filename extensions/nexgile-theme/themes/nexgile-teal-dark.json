{
  "name": "Nexgile Teal Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "newOperator": "#03D6C6",
    "stringLiteral": "#A8E6CF",
    "customLiteral": "#FFB347",
    "numberLiteral": "#FFB347",
    "enumMember": "#82AAFF",
    "macro": "#FFD700",
    "type": "#82AAFF",
    "class": "#82AAFF",
    "interface": "#82AAFF",
    "struct": "#82AAFF",
    "function": "#C792EA",
    "method": "#C792EA",
    "property": "#89DDFF",
    "variable.readonly": "#FFB347",
    "parameter": "#D4BFFF",
    "variable.defaultLibrary": "#03D6C6",
    "function.defaultLibrary": "#C792EA",
    "type.defaultLibrary": "#82AAFF",
    "keyword.async": "#03D6C6",
    "variable.declaration": "#E8EDF5",
    "typeParameter": "#5EEADF"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#546E7A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#03D6C6"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.of"
      ],
      "settings": {
        "foreground": "#03D6C6"
      }
    },
    {
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": {
        "foreground": "#A8E6CF"
      }
    },
    {
      "scope": ["string.template", "punctuation.definition.template-expression"],
      "settings": {
        "foreground": "#A8E6CF"
      }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#82AAFF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#E8EDF5"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#D4BFFF"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember", "constant.other", "constant.language"],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "punctuation"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name"],
      "settings": {
        "foreground": "#03D6C6"
      }
    },
    {
      "scope": ["support.constant.property-value.css", "constant.other.color"],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "scope": ["meta.selector.css"],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#546E7A"
      }
    },
    {
      "scope": ["entity.name.function.decorator", "meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#FFD700",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#03D6C6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#A8E6CF"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#546E7A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#03D6C6"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#F78C6C"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": {
        "foreground": "#E8EDF5"
      }
    },
    {
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#03D6C6"
      }
    },
    {
      "scope": ["support.type.property-name.toml", "entity.name.tag.yaml"],
      "settings": {
        "foreground": "#03D6C6"
      }
    },
    {
      "scope": ["constant.other.placeholder", "string.interpolated"],
      "settings": {
        "foreground": "#5EEADF"
      }
    },
    {
      "scope": ["entity.name.type.enum"],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": ["variable.other.property"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "foreground": "#4ADE80"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "foreground": "#FFB347"
      }
    }
  ],
